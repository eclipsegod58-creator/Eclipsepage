<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Capitán Scripts · Dos en 1</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      color: white;
      background:
        radial-gradient(circle at 15% 20%, rgba(110, 170, 255, 0.28), transparent 20%),
        radial-gradient(circle at 85% 75%, rgba(0, 190, 255, 0.14), transparent 18%),
        radial-gradient(circle at 50% 50%, rgba(60, 90, 255, 0.07), transparent 38%),
        linear-gradient(135deg, #020714, #08162e 45%, #10264b);
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 28px;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(rgba(255, 255, 255, 0.012) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.012) 1px, transparent 1px);
      background-size: 42px 42px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 1000px;
      padding: 34px;
      border-radius: 30px;
      background: rgba(255, 255, 255, 0.045);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(22px);
      box-shadow:
        0 35px 90px rgba(0, 0, 0, 0.48),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .header {
      text-align: center;
      margin-bottom: 30px;
    }

    .header h1 {
      margin: 0;
      font-size: 50px;
      font-weight: 700;
      letter-spacing: 1px;
      text-shadow: 0 0 28px rgba(120, 170, 255, 0.18);
    }

    .header p {
      margin-top: 8px;
      opacity: 0.72;
      font-size: 14px;
      letter-spacing: 0.8px;
    }

    .card-single {
      position: relative;
      padding: 24px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      overflow: hidden;
      transition: 0.25s ease;
      margin-bottom: 20px;
    }

    .card-single::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(120, 170, 255, 0.06), transparent 40%);
      pointer-events: none;
    }

    .card-single:hover {
      transform: translateY(-4px);
      border-color: rgba(120, 180, 255, 0.12);
      box-shadow: 0 14px 35px rgba(0, 0, 0, 0.2);
    }

    .card-single h2 {
      margin: 0 0 12px 0;
      font-size: 20px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .badge {
      background: rgba(70, 140, 255, 0.25);
      font-size: 12px;
      font-weight: 500;
      padding: 4px 14px;
      border-radius: 30px;
      letter-spacing: 0.4px;
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .badge-dos {
      background: rgba(255, 200, 50, 0.2);
      border-color: rgba(255, 200, 50, 0.15);
      color: #ffe484;
    }

    textarea {
      width: 100%;
      height: 120px;
      resize: none;
      border: none;
      outline: none;
      border-radius: 15px;
      padding: 15px;
      background: rgba(4, 12, 28, 0.78);
      color: #eaf0ff;
      font-size: 13px;
      line-height: 1.5;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
      font-family: 'Fira Code', 'Cascadia Code', monospace;
      letter-spacing: 0.2px;
    }

    .buttons {
      display: flex;
      gap: 12px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    button,
    a {
      border: none;
      text-decoration: none;
      color: white;
      padding: 11px 22px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 14px;
      background: rgba(70, 140, 255, 0.18);
      backdrop-filter: blur(8px);
      transition: 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-weight: 500;
    }

    button:hover,
    a:hover {
      background: rgba(95, 165, 255, 0.28);
      transform: translateY(-1px);
    }

    .footer {
      text-align: center;
      margin-top: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    #status {
      font-size: 13px;
      opacity: 0.78;
      min-height: 20px;
    }

    .copy-icon {
      font-size: 16px;
    }

    @media (max-width: 780px) {
      .header h1 {
        font-size: 38px;
      }
      .container {
        padding: 22px;
      }
    }
  </style>
</head>
<body>

  <div class="container">

    <div class="header">
      <h1>Capitán Scripts</h1>
      <p>duplicación + freeze trade · dos en 1</p>
    </div>

    <!-- Script Único: Duplicación + Freeze Trade (DOS EN 1) -->
    <div class="card-single">
      <h2>
        <span>⚡ Duplicación · Freeze</span>
        <span class="badge badge-dos">✨ dos en 1</span>
      </h2>

      <textarea id="mainScript" readonly>SCRIPT_KEY = "KEYLESS"
loadstring(game:HttpGet("https://api.jnkie.com/api/v1/luascripts/public/1869fa416bb1ddf6fcabeab6f91ce6f8b5592ac8a10493aac4abcf27bfe970cb/download"))()</textarea>

      <div class="buttons">
        <button onclick="copyScript('mainScript')">
          <span class="copy-icon">📋</span> Copiar
        </button>
      </div>
    </div>

    <div class="footer">
      <a href="https://discord.gg/u4RbK49N" target="_blank" style="background: rgba(88, 101, 242, 0.2);">
        💬 Discord
      </a>
      <div id="status">✅ Script dos en 1 listo</div>
    </div>

  </div>

  <script>
    // ----- Función de copiado -----
    function copyScript(id) {
      const box = document.getElementById(id);
      const text = box.value;

      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text)
          .then(() => {
            updateStatus('✅ Script copiado');
          })
          .catch(() => {
            fallbackCopy(text);
          });
      } else {
        fallbackCopy(text);
      }
    }

    function fallbackCopy(text) {
      const temp = document.createElement('textarea');
      temp.value = text;
      temp.setAttribute('readonly', '');
      temp.style.position = 'fixed';
      temp.style.left = '-9999px';
      temp.style.top = '0';
      document.body.appendChild(temp);
      temp.select();
      temp.setSelectionRange(0, 99999);

      try {
        const success = document.execCommand('copy');
        if (success) {
          updateStatus('✅ Script copiado');
        } else {
          updateStatus('❌ No se pudo copiar');
        }
      } catch (e) {
        updateStatus('❌ Error al copiar');
      }
      document.body.removeChild(temp);
    }

    function updateStatus(msg) {
      const el = document.getElementById('status');
      if (el) {
        el.textContent = msg;
        el.style.opacity = '1';
        setTimeout(() => {
          el.style.opacity = '0.78';
        }, 2500);
      }
    }

    // ---- inicialización ----
    document.addEventListener('DOMContentLoaded', function() {
      const status = document.getElementById('status');
      if (status) {
        status.textContent = '📋 Haz clic en "Copiar" para usar el script';
        setTimeout(() => {
          status.textContent = '✅ Duplicación + Freeze · todo en uno';
        }, 3000);
      }
    });
  </script>

</body>
</html>
